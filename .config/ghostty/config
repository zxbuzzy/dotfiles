theme = dark:TokyoNight Moon,light:Catppuccin Latte
font-family = JetBrainsMono Nerd Font
shell-integration-features = ssh-env
bell-features = no-title, no-attention

background-opacity = 0.8

mouse-hide-while-typing = true

macos-titlebar-style = tabs

keybind = ctrl+shift+arrow_left=resize_split:left,10
keybind = ctrl+shift+arrow_right=resize_split:right,10
keybind = ctrl+shift+arrow_down=resize_split:down,10
keybind = ctrl+shift+arrow_up=resize_split:up,10

gtk-single-instance = true
gtk-wide-tabs = false
gtk-toolbar-style = flat
window-padding-y = 3,0
window-padding-balance = true
window-decoration = false

command = $(which fish)
