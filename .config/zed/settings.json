{
  "icon_theme": "Catppuccin Frappé",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "session": {
    "trust_all_worktrees": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "base_keymap": "VSCode",
  "vim_mode": true,
  "ui_font_size": 16.0,
  "ui_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 14,
  "relative_line_numbers": "enabled",
  "theme": "Tokyo Night Moon",
  "terminal": {
    "dock": "right",
    "font_size": 13.0,
    "toolbar": {
      "breadcrumbs": false
    },
  },
  "vim": {
    "use_system_clipboard": "always",
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "tabs": {
    "show_diagnostics": "all",
    "file_icons": true,
    "git_status": true
  },
  "format_on_save": "off",
  "auto_install_extensions": {
    "html": true,
    "toml": true,
    "tokyo-night": true,
    "catpuccin-icons": true,
  }
}
