[
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle",
      "shift g g": "git_panel::ToggleFocus",
      "shift e": "project_panel::ToggleFocus"
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "ctrl-shift-l": "workspace::ActivatePaneRight",
      "ctrl-shift-s": "project_panel::OpenSplitHorizontal",
      "ctrl-shift-v": "project_panel::OpenSplitVertical"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "shift f f": "pane::DeploySearch",
      "ctrl-n": "search::SelectNextMatch",
      "ctrl-p": "search::SelectPreviousMatch",
      "ctrl-shift-r": "search::ToggleReplace"
    }
  },
  {
    "context": "GitPanel",
    "bindings": {
      "shift-enter": "git::StageAll",
      "ctrl-shift-g": "git::Push"
    }
  },
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      "ctrl-shift-v": "pane::SplitRight",
      "ctrl-shift-s": "pane::SplitDown",
      "ctrl-shift-l": "workspace::ActivatePaneRight",
      "ctrl-shift-h": "workspace::ActivatePaneLeft",
      "ctrl-shift-k": "workspace::ActivatePaneUp",
      "ctrl-shift-j": "workspace::ActivatePaneDown"
    }
  },
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !menu",
    "bindings": {
      "g c": "editor::ToggleComments"
    }
  }
]
