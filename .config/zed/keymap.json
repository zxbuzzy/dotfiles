[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-g": "git_panel::ToggleFocus",
    }
  },
  {
    "context": "ProjectPanel && not_editing || Terminal",
    "bindings": {
      "ctrl-shift-l": "workspace::ActivatePaneRight",
      "ctrl-shift-h": "workspace::ActivatePaneLeft",
      "ctrl-shift-s": "project_panel::OpenSplitHorizontal",
      "ctrl-shift-v": "project_panel::OpenSplitVertical",
      "ctrl-alt--": "workspace::DecreaseActiveDockSize",
      "ctrl-alt-=": "workspace::IncreaseActiveDockSize"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore"
    }
  },
  {
    "context": "Editor && VimControl && !VimWaiting && !menu",
    "bindings": {
      "space b": "editor::ToggleGitBlameInline",
      "shift-k": "editor::Hover",
      "space l f": "editor::Format",
      "space d": "diagnostics::Deploy",
      "space f f": "file_finder::Toggle",
      "space o": "tab_switcher::Toggle",
      "space e": "workspace::ToggleLeftDock",
      "space /": "workspace::NewSearch",
      "ctrl-n": "search::SelectNextMatch",
      "ctrl-p": "search::SelectPreviousMatch",
      "space t": "workspace::NewCenterTerminal",
      "+ +": "workspace::Save",
      "space c": "pane::CloseActiveItem",
      "ctrl-alt-h": "vim::ResizePaneLeft",
      "ctrl-alt-l": "vim::ResizePaneRight",
      "ctrl-alt-k": "vim::ResizePaneUp",
      "ctrl-alt-j": "vim::ResizePaneDown",
    }
  },
  {
    "context": "GitPanel",
    "bindings": {
      "shift-enter": "git::StageAll",
      "ctrl-shift-g": "git::Push"
    }
  },
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !VimObject",
    "bindings": {
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp"
    }
  },
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      "ctrl-shift-v": "pane::SplitRight",
      "ctrl-shift-s": "pane::SplitDown",
      "ctrl-shift-l": "workspace::ActivatePaneRight",
      "ctrl-shift-h": "workspace::ActivatePaneLeft",
      "ctrl-shift-k": "workspace::ActivatePaneUp",
      "ctrl-shift-j": "workspace::ActivatePaneDown"
    }
  },
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !menu",
    "bindings": {
      "g c": "editor::ToggleComments"
    }
  }
]
